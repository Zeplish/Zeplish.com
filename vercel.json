{
  "buildCommand": "pnpm --filter @workspace/zeplish run build",
  "outputDirectory": "artifacts/zeplish/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
